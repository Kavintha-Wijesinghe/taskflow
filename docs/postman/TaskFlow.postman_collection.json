{
  "info": {
    "_postman_id": "11e3ca90-54d9-4092-a3a7-949815a85203",
    "name": "TaskFlow REST API",
    "description": "Postman collection for the TaskFlow project and team task management API.\n\nRecommended order:\n1. Start PostgreSQL and the backend.\n2. Run Authentication > Log in as Administrator.\n3. Run protected requests. Postman preserves the HTTP-only authentication cookie automatically.\n4. Enter resource IDs in the selected environment where required.\n\nLocal backend: http://localhost:4000",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:4000"
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "API health",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/health"
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status code is 200\", function () { pm.response.to.have.status(200); });",
                  "pm.test(\"Response reports success\", function () { pm.expect(pm.response.json().success).to.eql(true); });"
                ]
              }
            }
          ]
        },
        {
          "name": "Database health",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/health/database"
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status code is 200\", function () { pm.response.to.have.status(200); });",
                  "pm.test(\"Database is healthy\", function () { pm.expect(pm.response.json().success).to.eql(true); });"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Log in as Administrator",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": "{{baseUrl}}/api/auth/login",
            "description": "Creates the HTTP-only authentication cookie used by later protected requests. Postman stores and sends the cookie automatically for the same host.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Login succeeds\", function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "pm.test(\"Authenticated user is returned\", function () { pm.expect(json.success).to.eql(true); pm.expect(json.user).to.be.an(\"object\"); });",
                  "if (json.user && json.user.id) { pm.environment.set(\"currentUserId\", json.user.id); }",
                  "if (json.token) { pm.environment.set(\"token\", json.token); }"
                ]
              }
            }
          ]
        },
        {
          "name": "Get authenticated user",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/auth/me"
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status code is 200\", function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "if (json.user && json.user.id) { pm.environment.set(\"currentUserId\", json.user.id); }"
                ]
              }
            }
          ]
        },
        {
          "name": "Log out",
          "request": {
            "method": "POST",
            "header": [],
            "url": "{{baseUrl}}/api/auth/logout",
            "description": "Clears the authentication cookie."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Logout succeeds\", function () { pm.response.to.have.status(200); });"
                ]
              }
            }
          ]
        }
      ]
    },
