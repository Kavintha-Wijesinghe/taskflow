              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"User is created\", function () { pm.expect(pm.response.code).to.be.oneOf([200, 201]); });",
                  "const json = pm.response.json();",
                  "if (json.user && json.user.id) { pm.environment.set(\"userId\", json.user.id); pm.environment.set(\"teamMemberId\", json.user.id); }"
                ]
              }
            }
          ]
